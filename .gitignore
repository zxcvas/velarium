# Build outputs
**/bin/
**/obj/
# For skeleton phase we commit a minimal runnable set in dist/ (exe + companions)
# Later we can decide to .gitignore dist/ and rely purely on build.ps1
dist/*.pdb
# dist/Velarium.deps.json
# dist/Velarium.dll
# dist/Velarium.runtimeconfig.json
# Keep only pdb ignored for cleanliness. The others + exe make the placeholder runnable post-clone.

# Inspiration / reference material — never commit (screenshots, PDFs, mood boards, etc.)
INSP/

# IDE / editor
.vs/
.vscode/
*.user
*.suo

# OS
Thumbs.db
.DS_Store

# Logs / temp
*.log
*.tmp
Session/
DUMP/

# Local game saves
saves/

# Godot or other if added later (uncomment if used)
# .import/
# export.cfg
# export_presets.cfg

# Python / node if used
__pycache__/
*.py[cod]
node_modules/
